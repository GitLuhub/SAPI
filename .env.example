# ============================================================
# SAPI — Variables de Entorno
# Copia este archivo como .env y ajusta los valores.
# Las variables marcadas con [PROD] son críticas en producción.
# ============================================================

# ----------------------------------------
# Entorno de ejecución
# ----------------------------------------
# "development" → cookies sin secure, logs legibles
# "production"  → cookies con secure=True, logs JSON, HTTPS requerido
ENVIRONMENT=development                          # [PROD] cambiar a "production"

# ----------------------------------------
# Seguridad JWT
# ----------------------------------------
SECRET_KEY=change-this-to-a-secure-random-string-in-production-minimum-32-characters  # [PROD] usar openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----------------------------------------
# URLs y CORS
# ----------------------------------------
FRONTEND_URL=http://localhost:3000              # [PROD] https://tu-dominio.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost  # [PROD] https://tu-dominio.com

# ----------------------------------------
# Base de Datos PostgreSQL
# ----------------------------------------
DATABASE_URL=postgresql+psycopg2://sapi_user:sapi_password@db:5432/sapi_db  # [PROD] usar credenciales seguras

# ----------------------------------------
# Redis / Celery
# ----------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ----------------------------------------
# IA — Google Gemini
# ----------------------------------------
GEMINI_API_KEY=                                  # [PROD] obtener en https://makersuite.google.com
AI_CLASSIFICATION_THRESHOLD=0.7
AI_EXTRACTION_THRESHOLD=0.6

# ----------------------------------------
# Almacenamiento de archivos
# ----------------------------------------
# STORAGE_PROVIDER: LOCAL (desarrollo) | AWS_S3 (producción)
STORAGE_PROVIDER=LOCAL                           # [PROD] AWS_S3
LOCAL_STORAGE_PATH=/app/uploads
OBJECT_STORAGE_BUCKET_NAME=sapi-documents
AWS_ACCESS_KEY_ID=                               # [PROD] requerido con AWS_S3
AWS_SECRET_ACCESS_KEY=                           # [PROD] requerido con AWS_S3
AWS_REGION=us-east-1

# ----------------------------------------
# Email / Notificaciones
# ----------------------------------------
# EMAIL_PROVIDER: CONSOLE (desarrollo) | SMTP (producción)
EMAIL_PROVIDER=CONSOLE                           # [PROD] SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=                                   # [PROD] requerido con SMTP
SMTP_PASSWORD=                                   # [PROD] requerido con SMTP
SENDER_EMAIL=noreply@sapi.local

# ----------------------------------------
# SSL / TLS (Nginx)
# ----------------------------------------
# Para desarrollo local: ejecutar ./nginx/generate-certs.sh
# Para producción: colocar cert y key en nginx/ssl/ o usar Certbot.
# Estos valores son solo informativos; la ruta real la usa nginx/conf.d/default.conf.
SSL_CERT_PATH=./nginx/ssl/cert.pem               # [PROD] /ruta/a/tu/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem                 # [PROD] /ruta/a/tu/key.pem
