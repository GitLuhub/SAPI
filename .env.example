# SAPI - Environment Configuration

SECRET_KEY=change-this-to-a-secure-random-string-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql+psycopg2://sapi_user:sapi_password@db:5432/sapi_db

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

GEMINI_API_KEY= api_Gemini
AI_CLASSIFICATION_THRESHOLD=0.7
AI_EXTRACTION_THRESHOLD=0.6

OBJECT_STORAGE_PROVIDER=LOCAL
OBJECT_STORAGE_BUCKET_NAME=sapi-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
LOCAL_STORAGE_PATH=/app/uploads

EMAIL_PROVIDER=CONSOLE
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SENDER_EMAIL=noreply@sapi.local
